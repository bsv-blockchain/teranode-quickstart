# Teranode Quickstart environment
#
# Copy to .env and edit (or run ./setup.sh to generate it).
# This file is committed; .env is git-ignored so your customisations
# never produce diffs when you `git pull`.

# === Version pin ===
# Bumped by ./update.sh after checking github.com/bsv-blockchain/teranode/releases/latest
TERANODE_VERSION=v0.14.3

# === Network ===
# One of: mainnet | testnet | regtest
TERANODE_NETWORK=testnet

# SETTINGS_CONTEXT is docker.m for all networks; the `network` env var selects
# the live network. Leave this as docker.m unless you know you need a different leaf.
SETTINGS_CONTEXT=docker.m

# === Host binding ===
# Controls ONLY these 3 ports — everything else (RPC, Grafana, Prometheus,
# Kafka, Postgres, Aerospike) stays hardcoded to 127.0.0.1 regardless.
#
#   8090  asset viewer UI
#   8000  asset-cache public API (full mode)
#   9905  P2P (full mode only)
#
# 127.0.0.1 = localhost only (safe default, works behind NAT)
# 0.0.0.0   = all interfaces (needed when a reverse proxy / firewall on
#             another host needs to reach these 3 ports directly)
HOST_IP=127.0.0.1

# === Aerospike edition ===
# aerospike-ee = Enterprise (evaluation mode, 1TB UTXO) — default
# aerospike    = Community Edition (640GB cap)
AEROSPIKE_SERVICE=aerospike-ee

# === Go runtime tuning ===
# Higher value reduces CPU pressure at cost of more RAM. 100 is Go default.
GOGC=200

# === Log verbosity ===
# INFO (default) | DEBUG | WARN | ERROR
# Raise to DEBUG when diagnosing issues; expect significantly more log volume.
LOG_LEVEL=INFO

# === Run mode ===
# listen_only = receives blocks but does not serve asset API or accept inbound P2P.
# Leave blank (unset) for full mode — requires the two public endpoints below.
LISTEN_MODE=listen_only

# === Full-mode public endpoints (listen-only = leave blank) ===
# Quickstart does NOT set up a reverse proxy or TLS for you. Bring your own
# (Caddy, Cloudflare Tunnel, nginx+Let's Encrypt, VPS with domain) and point
# these values at it. ASSET_PUBLIC_URL must be the full endpoint including
# /api/v1 (e.g. https://node.example.com/api/v1). After start.sh,
# lib/reachability.sh will probe these to flag misconfiguration.
ASSET_PUBLIC_URL=
P2P_ADVERTISE_ADDR=

# === RPC credentials ===
# Generated by setup.sh (always — quickstart does not ship a blank-RPC config).
# You can also set these manually. Keep the password strong; the RPC port is
# loopback-only by default but that's not a substitute for real auth.
RPC_USER=
RPC_PASS=

# === Client identity shown in explorer ===
# setup.sh defaults this to teranode-<4 random hex> so each install is distinct.
CLIENT_NAME=teranode-default

# === Postgres password ===
# Default is fine for a local node. Only change if you expose postgres externally.
POSTGRES_PASSWORD=teranode_change_me

# === Archival mode ===
# Set to true to run the blockpersister service (keeps full raw block history on disk).
# Leave false for most operators — Teranode prunes spent outputs after 288 blocks by
# default, which is the recommended setting. Archival mode significantly increases
# disk usage but preserves historical block data for indexers / explorers / research.
ARCHIVAL=false

# === UTXO snapshot seeding (optional, faster initial sync) ===
# Supply a SEED_HASH (the block hash the snapshot was taken at) plus one source:
#   SEED_URL  — snapshot will be downloaded + extracted (teratestnet has a
#               canonical URL; for teratestnet you can omit SEED_URL and seed.sh
#               will derive it from SEED_HASH)
#   SEED_DIR  — path to a local directory containing seed data you already have
#               (use this for mainnet / standard BSV testnet — no canonical
#               download URL exists, bring your own)
#
# Known-good teratestnet snapshot (as of v0.14.x):
#   SEED_HASH=000000002ea94a515ad9fd40d710fd249fe8610acef7b74f459446812d565187
#   (URL derived: https://svnode-snapshots.bsvb.tech/teratestnet/<hash>.zip)
#
# Snapshots are typically pruned; if you need full historical TX data, skip
# seeding and let the node sync from scratch.
SEED_HASH=
SEED_URL=
SEED_DIR=
