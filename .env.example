# Teranode Quickstart environment
#
# Copy to .env and edit (or run ./setup.sh to generate it).
# This file is committed; .env is git-ignored so your customisations
# never produce diffs when you `git pull`.

# === Version pin ===
# Bumped by ./update.sh after checking github.com/bsv-blockchain/teranode/releases/latest
TERANODE_VERSION=v0.14.3

# === Network ===
# One of: mainnet | testnet | regtest | teratestnet
# This is read directly by Teranode (matches settings.conf `network` key) and
# also tells the quickstart scripts which network you're on.
network=testnet

# SETTINGS_CONTEXT is docker.m for all networks; the `network` value above
# selects the live network. Leave this as docker.m unless you know you need a different leaf.
SETTINGS_CONTEXT=docker.m

# === Per-network consensus knobs ===
# setup.sh writes per-network defaults below. Edit if you know what you need.
#
#   minminingtxfee — fee floor (BSV/KB). 0 = accept anything.
#     mainnet     0.00000100  (100 sat/kb)
#     testnet     0.00000001  (1 sat/kb)
#     teratestnet 0.00000001  (1 sat/kb)
#     regtest     0           (no floor — local testing)
#
#   blockmaxsize — mining policy soft limit on block size (bytes).
#     mainnet/testnet/regtest 4294967296   (4 GiB)
#     teratestnet             1073741824   (1 GiB — capped for shared test network)
#
#   excessiveblocksize — consensus-level absolute max block size (bytes).
#     mainnet/testnet/regtest 10737418240  (10 GiB)
#     teratestnet             1073741824   (1 GiB — capped for shared test network)
minminingtxfee=0.00000001
blockmaxsize=4294967296
excessiveblocksize=10737418240

# === Host binding ===
# Controls ONLY these 3 ports — everything else (RPC, Grafana, Prometheus,
# Kafka, Postgres, Aerospike) stays hardcoded to 127.0.0.1 regardless.
#
#   8090  asset viewer UI                           (always on)
#   8000  asset-cache public API                    (p2p profile only)
#   9905  P2P inbound peer connections              (p2p profile only)
#
# 127.0.0.1 = localhost only (safe default, works behind NAT)
# 0.0.0.0   = all interfaces (needed when a reverse proxy / firewall on
#             another host needs to reach these 3 ports directly)
HOST_IP=127.0.0.1

# === Go runtime tuning ===
# Higher value reduces CPU pressure at cost of more RAM. 100 is Go default.
GOGC=200

# === Log verbosity ===
# INFO (default) | DEBUG | WARN | ERROR
# Raise to DEBUG when diagnosing issues; expect significantly more log volume.
logLevel=INFO

# === Run mode ===
# listen_only = receives blocks but does not serve asset API or accept inbound P2P.
# full        = serves asset API + accepts inbound P2P; requires the two
#               public endpoints below + COMPOSE_PROFILES containing 'p2p'.
listen_mode=listen_only

# === Full-mode public endpoints (listen-only = leave blank) ===
# Quickstart does NOT set up a reverse proxy or TLS for you. Bring your own
# (Caddy, Cloudflare Tunnel, nginx+Let's Encrypt, VPS with domain) and point
# these values at it.
#
#   asset_httpPublicAddress  — full HTTPS URL including /api/v1
#                              e.g. https://node.example.com/api/v1
#   p2p_advertise_addresses  — libp2p multiaddr; one of:
#                              /dns4/<hostname>/tcp/9905   (DNS, recommended)
#                              /ip4/<ip>/tcp/9905          (IPv4 literal)
#                              /ip6/<ip>/tcp/9905          (IPv6 literal)
#
# After start.sh, lib/reachability.sh probes these to flag misconfiguration.
asset_httpPublicAddress=
p2p_advertise_addresses=

# === RPC credentials ===
# Generated by setup.sh (always — quickstart does not ship a blank-RPC config).
# You can also set these manually. Keep the password strong; the RPC port is
# loopback-only by default but that's not a substitute for real auth.
rpc_user=
rpc_pass=

# === Client identity shown in explorer ===
# setup.sh defaults this to teranode-<4 random hex> so each install is distinct.
clientName=teranode-default

# === Misc Teranode defaults for quickstart ===
p2p_health_check_enabled=false

# === Postgres password ===
# Generated by setup.sh. This protects the postgres superuser only; the
# Teranode services connect with a separate role (teranode:teranode) hardcoded
# in upstream settings.conf for the docker.m context, so rotating that password
# requires a different upstream context. Postgres is loopback-only by default.
POSTGRES_PASSWORD=teranode_change_me

# === Compose profiles — controls which optional services run ===
# Comma-separated list. `docker compose up -d` reads this directly from .env;
# no need to pass --profile flags. Each tag toggles one service:
#
#   legacy         — legacy P2P bridge (BSV original wire protocol). On by default.
#   p2p            — Teranode P2P peer service. On by default. The listen_mode
#                    var above (active vs passive) controls behaviour, not
#                    whether this service runs.
#   blockpersister — archival mode: keeps full raw block history on disk.
#                    Off by default. Most operators don't need it (Teranode
#                    prunes spent UTXOs after 288 blocks). Useful for indexers /
#                    explorers / research. Significant disk cost.
#   seeding        — seeder service, one-shot UTXO snapshot loader.
#                    Off by default. Activated by ./seed.sh; don't set here.
COMPOSE_PROFILES=legacy,p2p

# === UTXO snapshot seeding (optional, faster initial sync) ===
# Supply a SEED_HASH (the block hash the snapshot was taken at) plus one source:
#   SEED_URL  — snapshot will be downloaded + extracted (teratestnet has a
#               canonical URL; for teratestnet you can omit SEED_URL and seed.sh
#               will derive it from SEED_HASH)
#   SEED_DIR  — path to a local directory containing seed data you already have
#               (use this for mainnet / standard BSV testnet — no canonical
#               download URL exists, bring your own)
#
# Known-good teratestnet snapshot (as of v0.14.x):
#   SEED_HASH=000000002ea94a515ad9fd40d710fd249fe8610acef7b74f459446812d565187
#   (URL derived: https://svnode-snapshots.bsvb.tech/teratestnet/<hash>.zip)
#
# Snapshots are typically pruned; if you need full historical TX data, skip
# seeding and let the node sync from scratch.
SEED_HASH=
SEED_URL=
SEED_DIR=
